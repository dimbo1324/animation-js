# Dependencies
node_modules/
yarn.lock
pnpm-lock.yaml
bun.lockb

# package-lock.json IS tracked on purpose: CI runs `npm ci`, which needs it,
# and a reproducible tooling install is worth the diff noise.

# Build outputs
dist/
build/
out/
.cache/
_site/

# IDE and editor
# .vscode/ is tracked on purpose: shared formatter and linter settings.
.idea/
*.swp
*.swo
*~
.vim/
*.sublime-project
*.sublime-workspace
.editorconfig.local

# Runtime and logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment
.env
.env.local
.env.*.local

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# Testing
coverage/
.nyc_output/

# Python bytecode from scripts/ai/
__pycache__/
*.py[cod]

# Temporary files
*.tmp
*.temp
tmp/
temp/
