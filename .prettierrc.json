{
  "printWidth": 72,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "quoteProps": "consistent",
  "trailingComma": "all",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "singleAttributePerLine": true,
  "objectWrap": "preserve",
  "experimentalOperatorPosition": "start",
  "htmlWhitespaceSensitivity": "css",
  "embeddedLanguageFormatting": "auto",
  "proseWrap": "preserve",
  "endOfLine": "lf",
  "overrides": [
    {
      "files": ["*.md"],
      "options": {
        "printWidth": 78
      }
    },
    {
      "files": ["*.json", "*.yml", "*.yaml"],
      "options": {
        "printWidth": 78
      }
    }
  ]
}
