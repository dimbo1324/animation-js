#!/bin/sh
#
# Enforce `type: what and why` commit messages.
#
# Rejected: `fix`, `update`, `wip`, `changes`, `final`, `123`, and anything
# that does not say what changed.

MESSAGE_FILE="$1"
SUBJECT=$(head -n 1 "$MESSAGE_FILE")

# Merge, revert, and fixup commits are generated by git itself.
case "$SUBJECT" in
  Merge\ *|Revert\ *|fixup!\ *|squash!\ *) exit 0 ;;
esac

PATTERN='^(feat|fix|refactor|perf|style|chore|ci|docs|test|build|revert)(\([a-z0-9._/-]+\))?!?: .{8,}'

if ! printf '%s' "$SUBJECT" | grep -Eq "$PATTERN"; then
  cat >&2 <<MESSAGE

  BLOCKED: commit message does not follow the project convention.

  Got:      $SUBJECT

  Expected: type: short description of what and why
  Types:    feat fix refactor perf style chore ci docs test build revert

  Examples:
    feat: add walker scene with squash-and-stretch rig
    perf: measure tile bounds once per drag instead of per pointer move
    refactor(core): split scheduler out of the reactive layer

MESSAGE
  exit 1
fi

if [ "${#SUBJECT}" -gt 72 ]; then
  echo "" >&2
  echo "  BLOCKED: subject line is ${#SUBJECT} characters; keep it under 72." >&2
  echo "  Move the detail into the commit body." >&2
  echo "" >&2
  exit 1
fi

exit 0
